{
  "name": "web-projects",
  "license": "MIT",
  "author": {
    "name": "Kang Myunggil",
    "email": "siluat@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siluat/web-projects.git"
  },
  "scripts": {
    "prepare": "lefthook install",
    "dev": "turbo dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "static-check": "turbo run check-types && turbo run format-and-lint",
    "version-packages": "changeset version && node scripts/sync-jsr-versions.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@turbo/gen": "^2.9.1",
    "lefthook": "^2.0.9",
    "turbo": "^2.9.1"
  },
  "packageManager": "bun@1.3.4",
  "engines": {
    "node": ">=22.5.0",
    "bun": ">=1.3.4"
  },
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "playgrounds/*"
    ],
    "catalog": {
      "@types/bun": "^1.3.9",
      "lucide-react": "^0.525.0",
      "tsdown": "^0.21.7"
    }
  }
}
